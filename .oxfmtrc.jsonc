{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortImports": {
    "newlinesBetween": false,
  },
  "sortPackageJson": {
    "sortScripts": true,
  },
  "tabWidth": 2,
  "useTabs": false,
  "ignorePatterns": ["dist/", "dist-test/", "node_modules/", "package-lock.json", "*.tgz"],
}
